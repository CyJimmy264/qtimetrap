QWidget#sidebar_panel {
  background-color: #111827;
  border-right: 1px solid #2b3b4f;
}

QWidget#sidebar_logo {
  background-color: transparent;
}

QLabel#sidebar_logo_text {
  color: #e5e7eb;
  font-size: 18px;
  font-weight: 800;
}

QLabel#sidebar_heading {
  color: #9ca3af;
  font-size: 12px;
}

QLabel#sidebar_tasks_heading {
  color: #94a3b8;
  font-size: 11px;
  margin-top: 8px;
}

QPushButton#project_button {
  background-color: #0f172a;
  border: 1px solid #334155;
  color: #cbd5e1;
  font-size: 12px;
  font-weight: 700;
  text-align: left;
  padding-left: 10px;
}

QPushButton#project_button:checked {
  background-color: #1e293b;
  border: 2px solid #38bdf8;
  color: #f8fafc;
  font-weight: 800;
}

QPushButton#project_button:disabled {
  color: #64748b;
}

QPushButton#task_button {
  background-color: #111827;
  border: 1px solid #334155;
  color: #cbd5e1;
  font-size: 11px;
  text-align: left;
  padding-left: 10px;
}

QPushButton#task_button:checked {
  background-color: #1f2937;
  border: 2px solid #38bdf8;
  color: #f8fafc;
}

QPushButton#sidebar_toggle_button {
  background-color: #0f172a;
  border: 1px solid #334155;
  border-radius: 8px;
  color: #93c5fd;
  font-size: 13px;
  font-weight: 700;
}

QPushButton#sidebar_toggle_button:hover {
  background-color: #111827;
  border: 1px solid #38bdf8;
}

QPushButton#sidebar_archive_toggle {
  background-color: #0b1220;
  border: 1px solid #334155;
  color: #94a3b8;
  font-size: 16px;
  font-weight: 700;
}

QPushButton#sidebar_archive_toggle:hover {
  border: 1px solid #f59e0b;
  color: #fbbf24;
}

QPushButton#sidebar_archive_toggle:checked {
  background-color: #3b2f14;
  border: 2px solid #f59e0b;
  color: #fde68a;
}
